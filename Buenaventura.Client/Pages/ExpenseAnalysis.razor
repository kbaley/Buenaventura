@page "/expense-analysis"
@using ApexCharts
@using Buenaventura.Client.Components.DashboardCharts
@using Color = MudBlazor.Color
@inject IExpensesApi expensesApi

@attribute [Authorize]

<MudText Typo="Typo.h4" GutterBottom="true">Expense Analysis</MudText>

<MudGrid>
    <MudItem xs="12">
        <MudPaper Elevation="1" Class="pa-4">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Include hashtags"
                                  Value="@includeTagsForEdit"
                                  ValueChanged="OnIncludeTagsChanged"
                                  Clearable="true"
                                  Immediate="false"
                                  Placeholder="#EuropeTrip2026 #maintenance" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Exclude hashtags"
                                  Value="@excludeTagsForEdit"
                                  ValueChanged="OnExcludeTagsChanged"
                                  Clearable="true"
                                  Immediate="false"
                                  Placeholder="#personal #reimbursed" />
                </MudItem>
                @if (HasIncludeTags)
                {
                    <MudItem xs="12">
                        <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Size="MudBlazor.Size.Small">
                            <MudButton Variant="@(tagReportMode == TagReportMode.Project ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => SetTagReportMode(TagReportMode.Project))">
                                Project
                            </MudButton>
                            <MudButton Variant="@(tagReportMode == TagReportMode.Ongoing ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => SetTagReportMode(TagReportMode.Ongoing))">
                                Ongoing
                            </MudButton>
                        </MudButtonGroup>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>
    </MudItem>

    <!-- Monthly Expenses Line Chart -->
    @if (!IsProjectTagMode)
    {
        <MudItem xs="12" md="9">
            <LineChart
                IsLoading="isLoading"
                ChartData="@monthlyExpenseData"
                TrendLine="@monthlyExpenseTrendLine"
                Title="Monthly Expenses (Last 12 Months)"
                Height="350"
            />
        </MudItem>
    }

    <!-- Total Expenses This Month -->
    @if (IsProjectTagMode)
    {
        <MudItem xs="12" md="6">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6">Tagged Expenses</MudText>
                <MudText Typo="Typo.h4" Color="Color.Success">@projectTotal.ToString("C0")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6">Date Range</MudText>
                <MudText Typo="Typo.h5">@projectDateRange</MudText>
            </MudPaper>
        </MudItem>
    }
    else
    {
        <MudItem xs="12" md="3">
            <MudGrid>
                <MudItem xs="12">
                    <MudPaper Elevation="1" Class="pa-4">
                        <MudText Typo="Typo.h6">Expenses This Month</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Success">@(expensesThisMonth.ToString("C0"))</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12">
                    <MudPaper Elevation="1" Class="pa-4">
                        <MudText Typo="Typo.h6">Average Monthly Expenses</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Success">@(averageMonthlyExpenses.ToString("C0"))</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudItem>
    }

    <!-- Expense Breakdown by Category -->
    <MudItem xs="12" md="@(IsProjectTagMode ? 6 : 4)">
        <MudPaper Elevation="1" Class="pa-4" Height="335px">
            <ExpenseChart
                IsLoading="@isLoading"
                ExpenseData="@expenseData"
                Title="@ExpenseChartTitle"
            />
        </MudPaper>
    </MudItem>

    <!-- Expense Averages -->
    @if (!IsProjectTagMode)
    {
        <MudItem xs="12" md="4">
            <MudPaper Elevation="1" Class="pa-4" Height="335px">
                <ExpenseAveragesChart
                    IsLoading="isLoading"
                    ExpenseData="@expenseAveragesData"
                />
            </MudPaper>
        </MudItem>
    }

    <!-- Spending by Vendor -->
    <MudItem xs="12" md="@(IsProjectTagMode ? 6 : 4)">
        <MudPaper Elevation="1" Class="pa-4" Height="335px">
            @if (isLoading)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="280px" />
            }
            else
            {
                <ApexChart TItem="ReportDataPoint" Title="@VendorChartTitle" Height="300" Options="vendorChartOptions">
                    <ApexPointSeries TItem="ReportDataPoint"
                                     Items="vendorData"
                                     Name="Spending"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => e.Value)"
                                     SeriesType="SeriesType.Donut" />
                </ApexChart>
            }
        </MudPaper>
    </MudItem>

    <!-- Expense Category Monthly Breakdown Table -->
    <MudItem xs="12">
        <MudPaper Elevation="1" Class="pa-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Expense Categories by Month</MudText>
            <MudTable Items="@categoryMonthlyData" Dense="true" Hover="true" Bordered="true" Striped="true">
                <HeaderContent>
                    <MudTh>Category</MudTh>
                    @foreach (var month in lastTwelveMonths)
                    {
                        <MudTh>@month.ToString("MMM yyyy")</MudTh>
                    }
                    <MudTh>Total</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Category">
                        <MudLink Href="@($"expense-analysis/{context.CategoryId}")">
                            @context.CategoryName
                        </MudLink>
                    </MudTd>
                    @foreach (var month in lastTwelveMonths)
                    {
                        var categoryAmount = context.Amounts.SingleOrDefault(a => a.Date.Month == month.Month && a.Date.Year == month.Year);
                        var amount = categoryAmount?.Amount ?? 0m;
                        <MudTd DataLabel="@month.Date.ToString("MMM yyyy")">@amount.ToString("C0")</MudTd>
                    }
                    <MudTd DataLabel="Total">@context.Total.ToString("C0")</MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTh>Total</MudTh>
                    @foreach (var total in monthlyTotals)
                    {
                        <MudTh>@total.ToString("C0")</MudTh>
                    }
                    <MudTh>@grandTotal.ToString("C0")</MudTh>
                </FooterContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private bool isLoading = true;
    private decimal expensesThisMonth;
    private decimal averageMonthlyExpenses;
    private decimal projectTotal;
    private string projectDateRange = "";
    private IEnumerable<ReportDataPoint> expenseData = [];
    private IEnumerable<ExpenseAveragesDataPoint> expenseAveragesData = [];
    private IEnumerable<ReportDataPoint> monthlyExpenseData = [];
    private IEnumerable<ReportDataPoint> monthlyExpenseTrendLine = [];
    private List<DateTime> lastTwelveMonths = [];
    private List<CategoryTotal> categoryMonthlyData = [];
    private List<decimal> monthlyTotals = [];
    private decimal grandTotal;
    private List<ReportDataPoint> vendorData = [];
    private string includeTagsForEdit = "";
    private string excludeTagsForEdit = "";
    private TagReportMode tagReportMode = TagReportMode.Project;
    private readonly ApexChartOptions<ReportDataPoint> vendorChartOptions = Services.ChartOptions.GetDefaultOptions<ReportDataPoint>();
    private bool HasIncludeTags => TransactionTagFormatter.ParseTagText(includeTagsForEdit).Any();
    private bool IsProjectTagMode => HasIncludeTags && tagReportMode == TagReportMode.Project;
    private string ExpenseChartTitle => IsProjectTagMode
        ? "Expense Breakdown by Category"
        : "Expense Breakdown by Category (last 12 months)";
    private string VendorChartTitle => IsProjectTagMode
        ? "Spending by Vendor"
        : "Spending by Vendor (last 12 months)";

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        var includeFilter = TransactionTagFormatter.ToTagText(TransactionTagFormatter.ParseTagText(includeTagsForEdit));
        var excludeFilter = TransactionTagFormatter.ToTagText(TransactionTagFormatter.ParseTagText(excludeTagsForEdit));
        var allTime = IsProjectTagMode;
        var expenseBreakdownTask = expensesApi.GetExpenseTotalsByMonth(includeFilter, excludeFilter, allTime);
        var expenseTask = expensesApi.GetExpenseCategoryBreakdown(includeFilter, excludeFilter, allTime);
        var vendorDataTask = expensesApi.GetVendorData(includeFilter, excludeFilter, allTime);

        if (IsProjectTagMode)
        {
            await Task.WhenAll(expenseTask, expenseBreakdownTask, vendorDataTask);
            expenseAveragesData = [];
        }
        else
        {
            var expensesTask = expensesApi.GetThisMonthExpenses(includeFilter, excludeFilter);
            var expenseAveragesTask = expensesApi.GetExpenseAveragesData(includeFilter, excludeFilter);
            await Task.WhenAll(
                expensesTask,
                expenseTask,
                expenseAveragesTask,
                expenseBreakdownTask,
                vendorDataTask
            );

            expensesThisMonth = -(await expensesTask);
            expenseAveragesData = await expenseAveragesTask;
        }

        expenseData = await expenseTask;
        vendorData = await vendorDataTask;
        var expenseBreakdown = await expenseBreakdownTask;
        projectTotal = expenseBreakdown.Total;
        projectDateRange = GetProjectDateRange(expenseBreakdown);

        StateHasChanged();
        isLoading = false;

        GenerateData(expenseBreakdown, allTime);
        monthlyExpenseTrendLine = CalculateTrendLine(expenseBreakdown.MonthTotals?.ToList());
        averageMonthlyExpenses = CalculateAverageMonthlyExpenses(expenseBreakdown);
        categoryMonthlyData = expenseBreakdown.Expenses.ToList();
    }

    private async Task OnIncludeTagsChanged(string tags)
    {
        includeTagsForEdit = tags;
        await OnParametersSetAsync();
    }

    private async Task OnExcludeTagsChanged(string tags)
    {
        excludeTagsForEdit = tags;
        await OnParametersSetAsync();
    }

    private void SetTagReportMode(TagReportMode mode)
    {
        tagReportMode = mode;
        _ = OnParametersSetAsync();
    }

    private void GenerateData(CategoryTotals expenseBreakdown, bool allTime)
    {
        var currentDate = DateTime.Now;
        lastTwelveMonths = [];
        monthlyTotals = [];
        if (allTime && expenseBreakdown.MonthTotals != null)
        {
            var monthTotals = expenseBreakdown.MonthTotals.OrderBy(x => x.Date).ToList();
            lastTwelveMonths = monthTotals.Select(x => x.Date).ToList();
            monthlyTotals = monthTotals.Select(x => x.Amount).ToList();
            grandTotal = monthlyTotals.Sum();
            monthlyExpenseData = monthTotals.Select(x => new ReportDataPoint
            {
                Label = x.Date.ToString("MMM yyyy"),
                Value = x.Amount
            });
            return;
        }

        for (var i = 11; i >= 0; i--)
        {
            var date = currentDate.AddMonths(-i);
            monthlyTotals.Add(expenseBreakdown.Expenses
                .Select(x => x.Amounts.FirstOrDefault(a => a.Date.Month == date.Month && a.Date.Year == date.Year)?.Amount ?? 0m).Sum());
            lastTwelveMonths.Add(date);
        }
        grandTotal = monthlyTotals.Sum();


        if (expenseBreakdown.MonthTotals == null)
        {
            monthlyExpenseData = [];
            return;
        }

        monthlyExpenseData = expenseBreakdown.MonthTotals
            .OrderBy(x => x.Date)
            .Select(x => new ReportDataPoint
            {
                Label = x.Date.ToString("MMM yyyy"),
                Value = x.Amount,
            });
    }

    private List<ReportDataPoint> CalculateTrendLine(List<MonthlyAmount>? data)
    {
        if (data == null || data.Count < 2)
            return [];

        // Ignore the current month so we don't skew the results
        var n = data.Count - 1;
        if (n < 2)
        {
            return CreateFlatTrendLine(data.Take(n).ToList());
        }

        var sumX = 0.0;
        var sumY = 0.0;
        var sumXY = 0.0;
        var sumXX = 0.0;

        // Convert data points to numerical values for regression
        for (var i = 0; i < n; i++)
        {
            var y = (double)data[i].Amount;

            sumX += i;
            sumY += y;
            sumXY += i * y;
            sumXX += i * i;
        }

        // Calculate slope (m) and y-intercept (b) for y = mx + b
        var denominator = n * sumXX - sumX * sumX;
        if (denominator == 0)
        {
            return CreateFlatTrendLine(data.Take(n).ToList());
        }

        var slope = (n * sumXY - sumX * sumY) / denominator;
        var intercept = (sumY - slope * sumX) / n;

        // Generate trend line points
        var trendPoints = new List<ReportDataPoint>();
        for (var i = 0; i < n; i++)
        {
            var trendValue = slope * i + intercept;
            trendPoints.Add(new ReportDataPoint
            {
                Label = data[i].Date.ToString("MMM yyyy"),
                Value = (decimal)trendValue
            });
        }

        return trendPoints;
    }

    private static List<ReportDataPoint> CreateFlatTrendLine(List<MonthlyAmount> data)
    {
        if (data.Count == 0)
        {
            return [];
        }

        var average = data.Average(x => x.Amount);
        return data.Select(x => new ReportDataPoint
        {
            Label = x.Date.ToString("MMM yyyy"),
            Value = average
        }).ToList();
    }

    private static decimal CalculateAverageMonthlyExpenses(CategoryTotals expenseBreakdown)
    {
        return (expenseBreakdown.MonthTotals?
            .Where(x => x.Date.Date != DateTime.Today.Date)
            .Sum(x => x.Amount) ?? 0m) / 11m;
    }

    private static string GetProjectDateRange(CategoryTotals expenseBreakdown)
    {
        if (expenseBreakdown.StartDate == null || expenseBreakdown.EndDate == null)
        {
            return "No tagged expenses";
        }

        return $"{expenseBreakdown.StartDate.Value:MMM d, yyyy} - {expenseBreakdown.EndDate.Value:MMM d, yyyy}";
    }

    private enum TagReportMode
    {
        Project,
        Ongoing
    }

}
