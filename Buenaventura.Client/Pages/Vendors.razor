@page "/vendors"
@inject IVendorsApi vendorsApi
@inject IDialogService dialogService
@inject NavigationManager navigationManager
@inject ISnackbar snackbar

@attribute [Authorize]

<MudGrid>
    <MudItem xs="12">
        <MudText Typo="Typo.h4" GutterBottom="true">Vendors</MudText>
    </MudItem>
</MudGrid>

<MudPaper Elevation="0" Class="pa-4 mt-4">
    <MudTable T="VendorModel" ServerData="ServerReload" Dense="true" Hover="true" Bordered="true" Striped="true"
              Loading="@loading" @ref="vendorTable" RowsPerPage="25">
        <ToolBarContent>
            <MudSpacer/>
            <MudDatePicker Label="Last posted before" @bind-Date="bulkDeleteBeforeDate" Class="mt-0 mr-2"/>
            <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep"
                           Color="Color.Error"
                           OnClick="BulkDeleteVendors"
                           Disabled="@(bulkDeleteBeforeDate == null)"
                           Title="Delete vendors last posted before this date"/>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel T="VendorModel" SortLabel="name">Name</MudTableSortLabel>
            </MudTh>
            <MudTh>Category</MudTh>
            <MudTh>
                <MudTableSortLabel T="VendorModel" SortLabel="lastPosted">Last Posted</MudTableSortLabel>
            </MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Category">@context.CategoryName</MudTd>
            <MudTd DataLabel="Last Posted">@FormatLastPosted(context.LastTransactionDate)</MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="2">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   OnClick="@(() => EditVendor(context))"
                                   Title="Edit vendor"/>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   OnClick="@(() => DeleteVendor(context))"
                                   Title="Delete vendor"/>
                </MudStack>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager/>
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<VendorModel>? vendorTable;
    private bool loading = true;
    private DateTime? bulkDeleteBeforeDate;

    private void EditVendor(VendorModel vendor)
    {
        navigationManager.NavigateTo($"/vendor/{vendor.VendorId}");
    }

    private async Task DeleteVendor(VendorModel vendor)
    {
        var parameters = new DialogParameters
        {
            ["ContentText"] = $"Are you sure you want to delete vendor {vendor.Name}?",
            ["ButtonText"] = "Delete",
            ["Color"] = Color.Error
        };

        var dialog = await dialogService.ShowAsync<ConfirmationDialog>("Delete Vendor", parameters);
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            await vendorsApi.DeleteVendor(vendor.VendorId);
            if (vendorTable != null)
            {
                await vendorTable.ReloadServerData();
            }
        }
    }

    private async Task<TableData<VendorModel>> ServerReload(TableState state, CancellationToken token)
    {
        loading = true;
        var sortBy = string.IsNullOrWhiteSpace(state.SortLabel) ? "name" : state.SortLabel;
        var result = await vendorsApi.GetVendors(
            state.Page,
            state.PageSize,
            sortBy,
            state.SortDirection == SortDirection.Descending);

        loading = false;
        return new TableData<VendorModel>
        {
            TotalItems = result.TotalCount,
            Items = result.Items
        };
    }

    private async Task BulkDeleteVendors()
    {
        if (bulkDeleteBeforeDate == null)
        {
            return;
        }

        var parameters = new DialogParameters
        {
            ["ContentText"] = $"Delete all vendors whose last posted transaction is before {bulkDeleteBeforeDate.Value:MM/dd/yyyy}?",
            ["ButtonText"] = "Delete",
            ["Color"] = Color.Error
        };

        var dialog = await dialogService.ShowAsync<ConfirmationDialog>("Bulk Delete Vendors", parameters);
        var result = await dialog.Result;
        if (result!.Canceled)
        {
            return;
        }

        var deletedCount = await vendorsApi.DeleteVendorsLastPostedBefore(bulkDeleteBeforeDate.Value);
        snackbar.Add($"Deleted {deletedCount} vendor{(deletedCount == 1 ? "" : "s")}.", Severity.Success);
        if (vendorTable != null)
        {
            await vendorTable.ReloadServerData();
        }
    }

    private static string FormatLastPosted(DateTime? date)
    {
        return date?.ToString("MM/dd/yyyy") ?? "";
    }
}
