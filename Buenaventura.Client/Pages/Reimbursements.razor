@page "/reports/reimbursements"
@inject IReimbursementsApi ReimbursementsApi

@attribute [Authorize]

<MudText Typo="Typo.h4" GutterBottom="true">Reimbursements</MudText>

@if (isLoading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else if (!report.Summary.HasTransactions)
{
    <MudAlert Severity="Severity.Info">No transactions are categorized as To be reimbursed yet.</MudAlert>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6">@BalanceLabel</MudText>
                <MudText Typo="Typo.h4" Color="@BalanceColor">@(Math.Abs(report.Summary.OutstandingBalance).ToString("C"))</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6">Oldest Outstanding</MudText>
                @if (report.Summary.OldestOutstandingDays.HasValue)
                {
                    <MudText Typo="Typo.h4" Color="Color.Warning">@report.Summary.OldestOutstandingDays.Value days</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Since @report.Summary.OldestOutstandingDate!.Value.ToString("MMM d, yyyy")
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.h4" Color="Color.Success">Clear</MudText>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6">Expenses Last 12 Months</MudText>
                <MudText Typo="Typo.h4" Color="Color.Error">@report.Summary.ExpensesLast12Months.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6">Repayments Last 12 Months</MudText>
                <MudText Typo="Typo.h4" Color="Color.Success">@report.Summary.RepaymentsLast12Months.ToString("C")</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Settle Selected</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="settlementName"
                                      Label="Settlement name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="settlementNotes"
                                      Label="Notes"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="3" Class="d-flex align-center justify-end">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@(!selectedTransactionIds.Any() || isSavingSettlement)"
                                   OnClick="CreateSettlement">
                            Settle @selectedTransactionIds.Count selected
                        </MudButton>
                    </MudItem>
                </MudGrid>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                    <MudChip T="string" Color="@SelectedDifferenceColor" Variant="Variant.Filled">
                        Selected Difference: @Math.Abs(SelectedDifference).ToString("C")
                    </MudChip>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @SelectedDifferenceLabel. Closing a settlement means the discrepancy is accepted and should no longer count as outstanding.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Unsettled Expenses</MudText>
                <MudTable Items="@report.UnsettledExpenses" Dense="true" Hover="true" Bordered="true" Striped="true">
                    <HeaderContent>
                        <MudTh></MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Vendor</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh Style="text-align: right">Owed</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudCheckBox T="bool"
                                         Value="@IsSelected(context.TransactionId)"
                                         ValueChanged="@(selected => SetSelected(context.TransactionId, selected))"
                                         Color="Color.Primary" />
                        </MudTd>
                        <MudTd DataLabel="Date">@context.TransactionDate.ToString("MM/dd/yyyy")</MudTd>
                        <MudTd DataLabel="Vendor">@context.Vendor</MudTd>
                        <MudTd DataLabel="Description">@context.Description</MudTd>
                        <MudTd DataLabel="Owed" Style="text-align: right">@context.ReimbursementAmount.ToString("C")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Unsettled Repayments</MudText>
                <MudTable Items="@report.UnsettledRepayments" Dense="true" Hover="true" Bordered="true" Striped="true">
                    <HeaderContent>
                        <MudTh></MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Vendor</MudTh>
                        <MudTh Style="text-align: right">Paid</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudCheckBox T="bool"
                                         Value="@IsSelected(context.TransactionId)"
                                         ValueChanged="@(selected => SetSelected(context.TransactionId, selected))"
                                         Color="Color.Primary" />
                        </MudTd>
                        <MudTd DataLabel="Date">@context.TransactionDate.ToString("MM/dd/yyyy")</MudTd>
                        <MudTd DataLabel="Vendor">@context.Vendor</MudTd>
                        <MudTd DataLabel="Paid" Style="text-align: right">@((-context.ReimbursementAmount).ToString("C"))</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Recent Settlements</MudText>
                <MudTable Items="@report.Settlements" Dense="true" Hover="true" Bordered="true" Striped="true">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Closed</MudTh>
                        <MudTh Style="text-align: right">Expenses</MudTh>
                        <MudTh Style="text-align: right">Repayments</MudTh>
                        <MudTh Style="text-align: right">Difference</MudTh>
                        <MudTh Style="text-align: right">Items</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">@context.Name</MudTd>
                        <MudTd DataLabel="Closed">@(context.ClosedDate?.ToString("MM/dd/yyyy") ?? "Open")</MudTd>
                        <MudTd DataLabel="Expenses" Style="text-align: right">@context.Expenses.ToString("C")</MudTd>
                        <MudTd DataLabel="Repayments" Style="text-align: right">@context.Repayments.ToString("C")</MudTd>
                        <MudTd DataLabel="Difference" Style="text-align: right">
                            <span style="color: @GetAmountColor(context.Difference)">
                                @context.Difference.ToString("C")
                            </span>
                        </MudTd>
                        <MudTd DataLabel="Items" Style="text-align: right">@context.TransactionCount</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Monthly Balance</MudText>
                <MudTable Items="@report.MonthlyRows" Dense="true" Hover="true" Bordered="true" Striped="true">
                    <HeaderContent>
                        <MudTh>Month</MudTh>
                        <MudTh Style="text-align: right">Expenses</MudTh>
                        <MudTh Style="text-align: right">Repayments</MudTh>
                        <MudTh Style="text-align: right">Net</MudTh>
                        <MudTh Style="text-align: right">Running Balance</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Month">@context.Month.ToString("MMM yyyy")</MudTd>
                        <MudTd DataLabel="Expenses" Style="text-align: right">@context.Expenses.ToString("C")</MudTd>
                        <MudTd DataLabel="Repayments" Style="text-align: right">@context.Repayments.ToString("C")</MudTd>
                        <MudTd DataLabel="Net" Style="text-align: right">
                            <span style="color: @GetAmountColor(context.Net)">
                                @context.Net.ToString("C")
                            </span>
                        </MudTd>
                        <MudTd DataLabel="Running Balance" Style="text-align: right">
                            <span style="color: @GetAmountColor(context.RunningBalance)">
                                @context.RunningBalance.ToString("C")
                            </span>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Recent Reimbursement Transactions</MudText>
                <MudTable Items="@report.RecentTransactions" Dense="true" Hover="true" Bordered="true" Striped="true">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Account</MudTh>
                        <MudTh>Vendor</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh Style="text-align: right">Transaction</MudTh>
                        <MudTh Style="text-align: right">Balance Impact</MudTh>
                        <MudTh Style="text-align: right">Running Balance</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date">@context.TransactionDate.ToString("MM/dd/yyyy")</MudTd>
                        <MudTd DataLabel="Account">@context.AccountName</MudTd>
                        <MudTd DataLabel="Vendor">@context.Vendor</MudTd>
                        <MudTd DataLabel="Description">@context.Description</MudTd>
                        <MudTd DataLabel="Transaction" Style="text-align: right">@context.Amount.ToString("C")</MudTd>
                        <MudTd DataLabel="Balance Impact" Style="text-align: right">
                            <span style="color: @GetAmountColor(context.ReimbursementAmount)">
                                @context.ReimbursementAmount.ToString("C")
                            </span>
                        </MudTd>
                        <MudTd DataLabel="Running Balance" Style="text-align: right">
                            <span style="color: @GetAmountColor(context.RunningBalance)">
                                @context.RunningBalance.ToString("C")
                            </span>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private bool isLoading = true;
    private bool isSavingSettlement;
    private ReimbursementReport report = new();
    private readonly HashSet<Guid> selectedTransactionIds = [];
    private string settlementName = $"Reimbursement settlement - {DateTime.Today:MMM yyyy}";
    private string settlementNotes = "";

    private decimal SelectedDifference => report.UnsettledExpenses
        .Concat(report.UnsettledRepayments)
        .Where(t => selectedTransactionIds.Contains(t.TransactionId))
        .Sum(t => t.ReimbursementAmount);

    private string SelectedDifferenceLabel => SelectedDifference switch
    {
        > 0 => "Selected expenses exceed selected repayments",
        < 0 => "Selected repayments exceed selected expenses",
        _ => "Selected expenses and repayments are balanced"
    };

    private Color SelectedDifferenceColor => SelectedDifference switch
    {
        > 0 => Color.Warning,
        < 0 => Color.Info,
        _ => Color.Success
    };

    private string BalanceLabel => report.Summary.OutstandingBalance switch
    {
        > 0 => "Outstanding",
        < 0 => "Surplus",
        _ => "Balance"
    };

    private Color BalanceColor => report.Summary.OutstandingBalance switch
    {
        > 0 => Color.Warning,
        < 0 => Color.Info,
        _ => Color.Success
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadReport();
    }

    private async Task LoadReport()
    {
        report = await ReimbursementsApi.GetReport();
        selectedTransactionIds.Clear();
        isLoading = false;
    }

    private bool IsSelected(Guid transactionId)
    {
        return selectedTransactionIds.Contains(transactionId);
    }

    private void SetSelected(Guid transactionId, bool selected)
    {
        if (selected)
        {
            selectedTransactionIds.Add(transactionId);
            return;
        }

        selectedTransactionIds.Remove(transactionId);
    }

    private async Task CreateSettlement()
    {
        isSavingSettlement = true;
        await ReimbursementsApi.CreateSettlement(new CreateReimbursementSettlementRequest
        {
            Name = settlementName,
            Notes = settlementNotes,
            CloseImmediately = true,
            TransactionIds = selectedTransactionIds.ToList()
        });
        settlementNotes = "";
        settlementName = $"Reimbursement settlement - {DateTime.Today:MMM yyyy}";
        await LoadReport();
        isSavingSettlement = false;
    }

    private static string GetAmountColor(decimal amount)
    {
        if (amount > 0)
        {
            return "var(--mud-palette-warning)";
        }

        if (amount < 0)
        {
            return "var(--mud-palette-info)";
        }

        return "inherit";
    }
}
