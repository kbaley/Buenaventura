@using ApexCharts
@using ChartOptions = Buenaventura.Client.Services.ChartOptions
@inject NavigationManager NavigationManager
@if (IsLoading)
{
    <MudGrid>
        <MudItem xs="12">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="20px" Width="30%"/>
        </MudItem>
        <MudItem xs="2" />
        <MudItem xs="5">
            <MudSkeleton SkeletonType="SkeletonType.Circle" Height="240px"/>
        </MudItem>
        <MudItem xs="2" />
        <MudItem xs="3">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="240px" Width="100%"/>
        </MudItem>
    </MudGrid>
}
else
{
    <ApexChart TItem="ReportDataPoint"
               Title="@Title"
               Height="300"
                Options="@chartOptions"
               OnDataPointSelection="OnDataPointSelection"
    >
        <ApexPointSeries
            TItem="ReportDataPoint"
            Items="expenseData"
            Name="Expenses"
            SeriesType="SeriesType.Pie"
            XValue="@(e => e.Label)"
            YValue="@(e => e.Value)"
            ShowDataLabels="true"/>
    </ApexChart>
}

@code {
    private ApexChartOptions<ReportDataPoint> chartOptions = ChartOptions.GetDefaultOptions<ReportDataPoint>();

    [Parameter] public bool IsLoading { get; set; } = true;
    [Parameter] public IEnumerable<ReportDataPoint> expenseData { get; set; } = [];
    [Parameter] public string Title { get; set; } = "Expense Breakdown by Category (last 12 months)";

    private void OnDataPointSelection(SelectedData<ReportDataPoint> selectedData)
    {
        if (selectedData.DataPoint?.Items?.FirstOrDefault()?.Id != null)
        {
            NavigationManager.NavigateTo($"/expense-analysis/{selectedData.DataPoint.Items.First().Id}");
        }
    }
}
