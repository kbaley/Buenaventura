@using System.Globalization
@using System.Text
@using System.Text.Json
@using System.Text.RegularExpressions
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ITransactionsApi TransactionsApi

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           OnClick="OpenFileUpload"
           StartIcon="@Icons.Material.Filled.Upload"
           Class="ml-2 d-none d-md-inline-flex">
    Upload File
</MudButton>

<MudButton Variant="Variant.Outlined"
           Color="Color.Primary"
           OnClick="OpenPasteDialog"
           StartIcon="@Icons.Material.Filled.ContentPaste"
           Class="ml-2 d-none d-md-inline-flex">
    Paste Transactions
</MudButton>

<InputFile id="fileInput" OnChange="OnInputFileChange" style="display:none" accept=".xls,.xlsx"/>

@code {
    private static readonly Regex PastedTransactionPattern = new(
        @"^(?<date>\d{2}/\d{2}/\d{4})\t(?<description>.+?)\t(?<amount>-?[\d,]+(?:\.\d{2})?)\s+USD$",
        RegexOptions.Compiled);

    [Parameter] public Guid AccountId { get; set; }
    [Parameter] public EventCallback OnTransactionsProcessed { get; set; }

    private async Task OpenFileUpload()
    {
        await JSRuntime.InvokeVoidAsync("openBulkTransactionFileInput");
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null)
            {
                return;
            }

            // Read the file content
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB max
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            // Process the Excel file using JSInterop
            var fileData = Convert.ToBase64String(memoryStream.ToArray());
            var excelData = await JSRuntime.InvokeAsync<string>("parseExcelFile", fileData);

            if (string.IsNullOrEmpty(excelData))
            {
                Snackbar.Add("Failed to parse Excel file", Severity.Error);
                return;
            }

            var pendingTransactions = ParseExcelData(excelData);

            await ReviewAndProcessTransactions(pendingTransactions);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error processing file: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenPasteDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<PasteTransactionsDialog>("Paste Transactions", options);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;

        if (result!.Canceled || result.Data is not string pastedText)
        {
            return;
        }

        var pendingTransactions = ParsePastedTransactions(pastedText);
        if (pendingTransactions.Count == 0)
        {
            Snackbar.Add("No valid transactions were found in the pasted text", Severity.Warning);
            return;
        }

        await ReviewAndProcessTransactions(pendingTransactions);
    }

    private List<PendingTransactionModel> ParseExcelData(string jsonData)
    {
        var rows = JsonSerializer.Deserialize<List<Dictionary<string, object>>>(jsonData);
        var transactions = new List<PendingTransactionModel>();

        if (rows == null || rows.Count == 0)
        {
            return transactions;
        }

        // Skip header rows (start from row 16 as per the screenshot)
        foreach (var row in rows)
        {
            if (!row.TryGetValue("Date", out var dateObj) ||
                !row.TryGetValue("Reference number", out var refObj) ||
                !row.TryGetValue("Card number", out var cardObj) ||
                !row.TryGetValue("Description", out var descObj) ||
                !row.TryGetValue("Dollars", out var amountObj))
            {
                continue;
            }

            // Parse the date
            if (dateObj is JsonElement { ValueKind: JsonValueKind.String } element 
                && DateTime.TryParse(element.GetString(), out var transactionDate))
            {
                // Parse the amount
                if (amountObj is JsonElement { ValueKind: JsonValueKind.String} amountStr && 
                    decimal.TryParse(amountStr.GetString()!.Replace(",", ""), out var amount))
                {
                    transactions.Add(new PendingTransactionModel
                    {
                        ReferenceNumber = refObj.ToString(),
                        TransactionDate = transactionDate,
                        CardNumber = cardObj.ToString(),
                        Description = descObj.ToString(),
                        Vendor = "",
                        Amount = amount,
                        IsSelected = true
                    });
                }
            }
        }

        return transactions;
    }

    private List<PendingTransactionModel> ParsePastedTransactions(string pastedText)
    {
        var transactions = new List<PendingTransactionModel>();
        var lines = pastedText
            .Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        foreach (var line in lines)
        {
            var match = PastedTransactionPattern.Match(line);
            if (!match.Success)
            {
                continue;
            }

            if (!DateTime.TryParseExact(match.Groups["date"].Value, "dd/MM/yyyy", CultureInfo.InvariantCulture,
                    DateTimeStyles.None, out var transactionDate))
            {
                continue;
            }

            if (!decimal.TryParse(match.Groups["amount"].Value.Replace(",", ""), NumberStyles.Number | NumberStyles.AllowLeadingSign,
                    CultureInfo.InvariantCulture, out var amount))
            {
                continue;
            }

            var description = match.Groups["description"].Value.Trim();
            transactions.Add(new PendingTransactionModel
            {
                TransactionDate = transactionDate,
                Description = description,
                Amount = amount,
                IsSelected = true
            });
        }

        return transactions;
    }

    private async Task CheckForProcessedTransactions(List<PendingTransactionModel> pendingTransactions)
    {
        if (pendingTransactions.Count == 0)
        {
            return;
        }

        var start = pendingTransactions.Min(t => t.TransactionDate).AddDays(-7);
        var end = pendingTransactions.Max(t => t.TransactionDate).AddDays(7);
        var existingTransactions = await TransactionsApi.GetAllTransactions(AccountId, start, end);

        foreach (var transaction in pendingTransactions)
        {
            if (!string.IsNullOrEmpty(transaction.ReferenceNumber))
            {
                var alreadyProcessed = existingTransactions.Items.Any(t =>
                    t.DownloadId == transaction.ReferenceNumber && t.TransactionDate == transaction.TransactionDate
                    && -t.Amount == transaction.Amount);

                if (alreadyProcessed)
                {
                    transaction.IsAlreadyProcessed = true;
                    transaction.IsSelected = false;
                    continue;
                }
            }

            var matchingTransactions = existingTransactions.Items
                .Where(t => t.TransactionDate.Date == transaction.TransactionDate.Date && -transaction.Amount == t.Amount)
                .Select(t => new
                {
                    Transaction = t,
                    Score = GetMatchingScore(transaction, t)
                })
                .OrderByDescending(t => t.Score)
                .ThenByDescending(t => !string.IsNullOrWhiteSpace(t.Transaction.Description))
                .ToList();

            if (matchingTransactions.Count == 0)
            {
                continue;
            }

            var bestMatch = matchingTransactions.First();
            if (bestMatch.Score >= 120 && matchingTransactions.Count(t => t.Score == bestMatch.Score) == 1)
            {
                transaction.IsAlreadyProcessed = true;
                transaction.IsSelected = false;
                transaction.PotentialMatch = bestMatch.Transaction;
                continue;
            }

            transaction.HasPotentialMatch = true;
            transaction.PotentialMatch = bestMatch.Transaction;
            transaction.IsSelected = true;
        }
    }

    private async Task ReviewAndProcessTransactions(List<PendingTransactionModel> pendingTransactions)
    {
        await CheckForProcessedTransactions(pendingTransactions);

        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true, CloseButton = true };
        var parameters = new DialogParameters
        {
            ["PendingTransactions"] = pendingTransactions,
            ["AccountId"] = AccountId
        };

        var dialog = await DialogService.ShowAsync<PendingTransactionsDialog>("Review Transactions", parameters, options);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;

        if (!result.Canceled && OnTransactionsProcessed.HasDelegate)
        {
            await OnTransactionsProcessed.InvokeAsync();
        }
    }

    private static int GetMatchingScore(PendingTransactionModel pendingTransaction, TransactionForDisplay existingTransaction)
    {
        var pendingText = NormalizeForMatching(pendingTransaction.Vendor, pendingTransaction.Description);
        var existingText = NormalizeForMatching(existingTransaction.Vendor, existingTransaction.Description);

        if (string.IsNullOrWhiteSpace(pendingText) || string.IsNullOrWhiteSpace(existingText))
        {
            return 0;
        }

        if (pendingText == existingText)
        {
            return 120;
        }

        if (pendingText.Contains(existingText, StringComparison.Ordinal) ||
            existingText.Contains(pendingText, StringComparison.Ordinal))
        {
            return 90;
        }

        var pendingTokens = pendingText.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var existingTokens = existingText.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var overlapCount = pendingTokens.Intersect(existingTokens).Count();

        return overlapCount * 20;
    }

    private static string NormalizeForMatching(params string?[] values)
    {
        var combined = string.Join(" ", values.Where(v => !string.IsNullOrWhiteSpace(v))).Trim();
        if (string.IsNullOrWhiteSpace(combined))
        {
            return string.Empty;
        }

        var builder = new StringBuilder(combined.Length);
        foreach (var character in combined.ToUpperInvariant())
        {
            builder.Append(char.IsLetterOrDigit(character) ? character : ' ');
        }

        return string.Join(" ", builder.ToString().Split(' ', StringSplitOptions.RemoveEmptyEntries));
    }
}
